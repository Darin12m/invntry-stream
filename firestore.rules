rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow authenticated users to read and write most collections
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Products collection rules
    match /products/{id} {
      allow read: if request.auth != null;
      // Allow create for authenticated users
      allow create: if request.auth != null;
      // Allow update only if the 'onHand' field is NOT being changed by the client.
      // This means clients can update other product fields, but 'onHand' is protected.
      // Only trusted backend functions (like Netlify functions) can modify 'onHand'.
      allow update: if request.auth != null && !("onHand" in request.resource.data.keys());
      allow delete: if request.auth != null;
    }

    // Stock Movements collection rules
    match /stock_movements/{id} {
      allow read: if request.auth != null;
      // Prevent any client-side writes to stock_movements.
      // Only trusted backend functions can create, update, or delete stock movements.
      allow write: if false;
    }

    // Invoices Server Copies collection rules
    match /invoices_server_copies/{id} {
      allow read: if request.auth != null;
      // Allow trusted backend functions to write to invoices_server_copies.
      // Clients are prevented from directly modifying these server-side copies.
      allow write: if false; // Changed to false to prevent client writes
    }

    // Activity Logs collection rules
    match /activityLogs/{logId} {
      allow read: if request.auth != null;
      // Allow only server-side writes (e.g., Netlify functions)
      allow create, update, delete: if false;
    }
  }
}